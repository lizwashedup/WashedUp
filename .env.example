# WashedUp — Environment Variables
# Copy to .env or .env.local and fill in values. Never commit .env / .env.local to git.
# All three are required for the app to run.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Admin: comma-separated user UUIDs who can manage Scene events (Profile → Manage Scene Events)
# EXPO_PUBLIC_ADMIN_USER_IDS=uuid1,uuid2
