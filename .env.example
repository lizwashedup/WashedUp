# WashedUp — Environment Variables
# Copy to .env or .env.local and fill in values. Never commit .env / .env.local to git.
# For EAS builds: set secrets in EAS dashboard (eas env:create) before production build.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for app.config.js (maps). Set GOOGLE_MAPS_API_KEY in EAS Secrets for production.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
