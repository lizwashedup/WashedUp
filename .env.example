# WashedUp — Environment Variables
# Copy to .env or .env.local and fill in values. Never commit .env / .env.local to git.
# All three are required for the app to run.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# OneSignal App ID (PUBLIC identifier, ships in the client; safe to commit). Required for push.
# A hardcoded fallback exists in hooks/usePushNotifications.ts, but ALWAYS keep this set so
# builds and OTAs carry it. An empty/missing value here caused the 2026-06 push outage.
EXPO_PUBLIC_ONESIGNAL_APP_ID=fc98cc7c-b325-4a45-b3d2-19527c280fca

# Admin: comma-separated user UUIDs who can manage Scene events (Profile → Manage Scene Events)
# EXPO_PUBLIC_ADMIN_USER_IDS=uuid1,uuid2

# PostHog product analytics (autocapture). Get the key from PostHog → Project settings → Project API key.
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your_project_api_key
