{
  "expo": {
    "name": "WashedUp",
    "slug": "washedup-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "washedupapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-branded.png",
      "resizeMode": "cover",
      "backgroundColor": "#FAF5EC"
    },
    "notification": {
      "icon": "./assets/images/app-icon.png",
      "color": "#B5522E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.washedup.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "config": {},
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDisplayName": "WashedUp",
        "NSCameraUsageDescription": "WashedUp needs camera access so you can take a profile photo.",
        "NSPhotoLibraryUsageDescription": "WashedUp needs access to your photos so you can share images in group chats and set your profile picture.",
        "NSLocationWhenInUseUsageDescription": "WashedUp uses your location to show plans near you and help you find events in Los Angeles.",
        "LSApplicationQueriesSchemes": ["comgooglemaps", "waze", "uber", "lyft"]
      },
      "entitlements": {
        "aps-environment": "production"
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          }
        ]
      }
    },
    "android": {
      "package": "com.washedup.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#B5522E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "WashedUp needs access to your photos so you can share images in group chats and set your profile picture.",
          "cameraPermission": "WashedUp needs camera access so you can take a profile photo."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow WashedUp to use your location to show plans near you."
        }
      ],
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      "expo-font",
      "expo-updates",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app-icon.png",
          "color": "#B5522E",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9584097f-8f32-4fce-ae36-e87c1ffd50cc"
      }
    },
    "owner": "washedup.app"
  }
}
